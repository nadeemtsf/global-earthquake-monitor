# ===========================================================================
# Global Earthquake Monitor — Backend Environment Variables
# ===========================================================================
#
# Copy this file to .env and fill in real values.
# NEVER commit a .env file containing real secrets.
#
#   cp .env.example .env
#
# ===========================================================================


# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Runtime environment. Controls docs exposure and log verbosity.
# Values: development | staging | production
ENV=development

# Set to false in production to hide /docs, /redoc, and /openapi.json.
ENABLE_DOCS=true


# ---------------------------------------------------------------------------
# CORS — React frontend origins
# ---------------------------------------------------------------------------

# Comma-separated list of origins that the React frontend is served from.
# Add your production Vercel/Netlify/Render URL here when deploying.
#
# Examples:
#   Development only:
#     CORS_ALLOWED_ORIGINS=http://localhost:5173
#   Development + production:
#     CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# ---------------------------------------------------------------------------
# USGS provider
# ---------------------------------------------------------------------------

# USGS FDSN Web Services earthquake query base URL.
# Only override if routing through a mirror or proxy.
USGS_API_BASE=https://earthquake.usgs.gov/fdsnws/event/1/query


# ---------------------------------------------------------------------------
# GDACS provider
# ---------------------------------------------------------------------------

# GDACS global disaster alert RSS/XML feed.
# Only override if routing through a mirror or proxy.
GDACS_RSS_URL=https://www.gdacs.org/xml/rss.xml


# ---------------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------------

# TTL in seconds for in-memory provider response cache.
# 600 = 10 minutes.
CACHE_TTL_SECONDS=600

# Directory for on-disk CSV and XML cache files.
# Path is relative to the backend/ working directory.
CACHE_DIR=.cache


# ---------------------------------------------------------------------------
# AI / Gemini
# ---------------------------------------------------------------------------

# Google Gemini API key used by the SeismicAI chat service.
# Obtain from: https://aistudio.google.com/app/apikey
# Leave blank to disable AI features without breaking other endpoints.
GOOGLE_API_KEY=


# ---------------------------------------------------------------------------
# Data pipeline
# ---------------------------------------------------------------------------

# Default minimum earthquake magnitude applied when no value is supplied
# by the client.
DEFAULT_MIN_MAGNITUDE=2.5

# Path to the top-level transforms/ directory that contains XSLT stylesheets.
# Relative to the repository root (i.e. one level above backend/).
XSLT_DIR=../transforms


# ---------------------------------------------------------------------------
# Security — API key authentication (issue #09)
# ---------------------------------------------------------------------------
#
# API_KEY_ENABLED controls whether the X-API-Key header check is enforced.
#
# Development (default): set API_KEY_ENABLED=false so the local Vite dev
# server (npm run dev on port 5173) can call the API without sending a key.
# No other bypass configuration is needed for local React development.
#
# Staging / production: set API_KEY_ENABLED=true and provide a strong random
# value for API_KEY.  Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# When API_KEY_ENABLED=true every request to a key-protected endpoint must
# include the header:
#   X-API-Key: <your-api-key>
#
# The /health endpoint is never key-protected regardless of this setting.
# ---------------------------------------------------------------------------

# Set to true to enforce key checking in staging/production.
API_KEY_ENABLED=false

# The shared secret API key.  Leave blank when API_KEY_ENABLED=false.
API_KEY=


# ---------------------------------------------------------------------------
# Rate limiting (issue #09)
# ---------------------------------------------------------------------------
#
# The backend uses a per-IP sliding-window rate limiter.
# /health, /docs, /redoc, and /openapi.json are always exempt.
#
# For local React development the defaults (60 req/min) are generous enough
# that normal development activity is never throttled.  If you hit the limit
# during heavy hot-reload testing, raise RATE_LIMIT_REQUESTS.
# ---------------------------------------------------------------------------

# Set to false to disable rate limiting entirely (e.g. when an upstream
# CDN or API gateway already enforces its own limits).
RATE_LIMIT_ENABLED=true

# Maximum number of requests allowed within the window (per client IP).
RATE_LIMIT_REQUESTS=60

# Sliding window duration in seconds.
RATE_LIMIT_WINDOW_SECONDS=60


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Root log level.  DEBUG surfaces API key bypass notices and rate-limit
# decisions.  INFO is the recommended production level.
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
